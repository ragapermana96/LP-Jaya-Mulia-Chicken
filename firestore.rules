rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn(); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'description', 'price', 'imageUrl']) &&
             data.name is string && data.name.size() > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.description is string &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() > 0;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /products/{productId} {
      allow list, get: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
